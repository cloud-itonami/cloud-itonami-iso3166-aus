#:culture{:id "aus.dish.lamington", :name "Lamington", :country "AUS", :kind :dish, :summary "Australian cake of sponge coated in chocolate sauce and desiccated coconut, originating from Queensland and believed to be named after Lord Lamington.", :url "https://en.wikipedia.org/wiki/Lamington", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "aus.dish.anzac-biscuit", :name "Anzac biscuit", :country "AUS", :kind :dish, :summary "Sweet oat biscuit popular in Australia and New Zealand, long associated with the Australian and New Zealand Army Corps established in World War I.", :url "https://en.wikipedia.org/wiki/Anzac_biscuit", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "aus.product.vegemite", :name "Vegemite", :country "AUS", :kind :product, :summary "Thick dark-brown Australian food spread made from brewers' yeast extract, developed in Melbourne in 1922 and considered a symbol of Australia.", :url "https://en.wikipedia.org/wiki/Vegemite", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "aus.beverage.flat-white", :name "Flat white", :country "AUS", :kind :beverage, :summary "Espresso-and-steamed-milk coffee drink whose invention is claimed by café owners in both Australia and New Zealand.", :url "https://en.wikipedia.org/wiki/Flat_white", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "aus.craft.didgeridoo", :name "Didgeridoo", :country "AUS", :kind :craft, :summary "Wind instrument developed by Aboriginal peoples of northern Australia at least 1,000 years ago, most strongly associated with Indigenous Australian music.", :url "https://en.wikipedia.org/wiki/Didgeridoo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "aus.festival.vivid-sydney", :name "Vivid Sydney", :country "AUS", :kind :festival, :summary "Annual festival of outdoor light installations, music and ideas held over three weeks in May and June in Sydney, New South Wales.", :url "https://en.wikipedia.org/wiki/Vivid_Sydney", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
